# Executive Mochi – Environment Variables
# Copy this file to .env.local and fill in the values

# ─────────────────────────────────────────────
# DATABASE (Required)
# Obtain from Railway / Neon / Supabase
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# ─────────────────────────────────────────────
# AUTHENTICATION (NextAuth v5)
# Generate a secret: openssl rand -hex 32
# ─────────────────────────────────────────────
AUTH_SECRET="your-32-char-secret-here"
AUTH_URL="http://localhost:3000"

NEXTAUTH_SECRET="your-32-char-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_BRAND_NAME="Executive Mochi"
NEXT_PUBLIC_BRAND_PHONE="+92-300-XXXXXXX"

# ─────────────────────────────────────────────
# VERCEL BLOB STORAGE (Product Image Uploads)
# Create a Blob store in Vercel Dashboard → Storage
# ─────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=""

# ─────────────────────────────────────────────
# GOOGLE CLOUD STORAGE (Product Images) – Legacy
# ─────────────────────────────────────────────
GCS_PROJECT_ID=""
GCS_BUCKET_NAME=""
GCS_CLIENT_EMAIL=""
GCS_PRIVATE_KEY=""

# ─────────────────────────────────────────────
# COURIER APIs (Section 4.3 – IF-SW-04 to 07)
# ─────────────────────────────────────────────
LEOPARDS_API_KEY=""
LEOPARDS_API_PASSWORD=""

POSTEX_API_TOKEN=""
POSTEX_PICKUP_ADDRESS_CODE=""

TRAX_USERNAME=""
TRAX_PASSWORD=""
TRAX_ACCOUNT_NO=""

# ─────────────────────────────────────────────
# PAYMENT GATEWAYS (Section 4.3 – IF-SW-01 to 03)
# ─────────────────────────────────────────────
SAFEPAY_API_KEY=""
SAFEPAY_WEBHOOK_SECRET=""

JAZZCASH_MERCHANT_ID=""
JAZZCASH_PASSWORD=""
JAZZCASH_INTEGRITY_SALT=""

# ─────────────────────────────────────────────
# SMS / WHATSAPP GATEWAY (COD Verification)
# ─────────────────────────────────────────────
SMS_GATEWAY_API_KEY=""
SMS_GATEWAY_SENDER_ID=""
WHATSAPP_GATEWAY_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""

# ─────────────────────────────────────────────
# ADMIN SEED CREDENTIALS (used only in seed.ts)
# ─────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@executivemochi.pk"
SEED_ADMIN_PASSWORD="ChangeMe@123"
SEED_ADMIN_NAME="Executive Mochi Admin"
